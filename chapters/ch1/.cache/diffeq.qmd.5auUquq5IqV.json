            "source": [
                "---\n",
                "engine: julia\n",
                "execute:\n",
                "    cache: true\n",
                "---\n",
                "\n",
                "# Differential Equations and Nonlinear Oscillations"
            ]
        },
        {
            "id": "2",
            "cell_type": "code",
            "metadata": {
            },
            "source": [
                "using CairoMakie, LaTeXStrings, LinearAlgebra"
            ],
            "outputs": [
            ],
            "execution_count": 1
        },
        {
            "id": "3",
            "cell_type": "markdown",
            "metadata": {
            },
            "source": [
            ]
        },
        {
            "id": "4",
            "cell_type": "code",
            "metadata": {
            },
            "source": [
                "const G = 1.0\n",
                "const M = 1.0;"
            ],
            "outputs": [
            ],
            "execution_count": 1
        },
        {
            "id": "5",
            "cell_type": "markdown",
            "metadata": {
            },
            "source": [
            ]
        },
        {
            "id": "6",
            "cell_type": "code",
            "metadata": {
            },
            "source": [
                "function f(t, state)\n",
                "    pos, vel = state\n",
                "    acc = - G * M * pos / norm(pos)^3\n",
                "    return [vel, acc]\n",
                "end;"
            ],
            "outputs": [
            ],
            "execution_count": 1
        },
        {
            "id": "7",
            "cell_type": "markdown",
            "metadata": {
            },
            "source": [
            ]
        },
        {
            "id": "8",
            "cell_type": "code",
            "metadata": {
            },
            "source": [
                "mutable struct Star{T}\n",
                "    state::Array{T}\n",
                "    pos_hist\n",
                "end;"
            ],
            "outputs": [
            ],
            "execution_count": 1
        },
        {
            "id": "9",
            "cell_type": "markdown",
            "metadata": {
            },
            "source": [
            ]
        },
        {
            "id": "10",
            "cell_type": "code",
            "metadata": {
            },
            "source": [
                "function rk4(t, y, force, dt)\n",
                "    \"\"\"\n",
                "    Function to calculate the next timestep using:\n",
                "        4th-order Runge-Kutta\n",
                "    \"\"\"\n",
                "    k1 = force(t, y)\n",
                "    k2 = force(t + 0.5 * dt, y + 0.5 * k1 * dt)\n",
                "    k3 = force(t + 0.5 * dt, y + 0.5 * k2 * dt)\n",
                "    k4 = force(t + dt, y + k3 * dt)\n",
                "\n",
                "    y_new = y + dt * (k1 + 2.0*k2 + 2.0*k3 + k4) / 6.0\n",
                "end;"
            ],
            "outputs": [
            ],
            "execution_count": 1
        },
        {
            "id": "11",
            "cell_type": "markdown",
            "metadata": {
            },
            "source": [
            ]
        },
        {
            "id": "12",
            "cell_type": "code",
            "metadata": {
            },
            "source": [
                "function orbit(t_start, t_end, dt, star, force)\n",
                "    t = t_start\n",
                "    while t < t_end \n",
                "        new_state = rk4(t, star.state, force, dt)\n",
                "        star.state = new_state\n",
                "        push!(star.pos_hist, star.state[1])\n",
                "        t += dt\n",
                "    end\n",
                "    star.pos_hist = reduce(hcat, star.pos_hist)'\n",
                "end;"
            ],
            "outputs": [
            ],
            "execution_count": 1
        },
        {
            "id": "13",
            "cell_type": "markdown",
            "metadata": {
            },
            "source": [
            ]
        },
        {
            "id": "14",
            "cell_type": "code",
            "metadata": {
            },
            "source": [
                "start_pos = [1.0, 0.0, 0.0]\n",
                "start_vel = [0.0, 1.0, 0.0]\n",
                "start_state = [start_pos, start_vel]\n",
                "star = Star(start_state, [start_state[1]])\n",
                "\n",
                "h = 1e-4\n",
                "norbits = 1.0\n",
                "t_end = 2 * pi * norbits\n",
                "orbit(0.0, t_end, h, star, f);"
            ],
            "outputs": [
            ],
            "execution_count": 1
        },
        {
            "id": "15",
            "cell_type": "markdown",
            "metadata": {
            },
            "source": [
            ]
        },
        {
            "id": "16",
            "cell_type": "code",
            "metadata": {
            },
            "source": [
                "function plot_orbit(star, name)\n",
                "    inch = 96\n",
                "    pt = 4/3\n",
                "\n",
                "    fig = Figure(size=(10inch, 7inch), fontsize=16pt)\n",
                "    ax = Axis(fig[1, 1], \n",
                "            xlabel = \"x\",\n",
                "            ylabel = \"y\",\n",
                "            title=L\"Orbit around a Point Mass ($\\Delta t$ = %$(h))\",\n",
                "            aspect = DataAspect())\n",
                "\n",
                "    plot!(ax, star.pos_hist[:, 1], star.pos_hist[:, 2])\n",
                "    save(name, fig)\n",
                "end;"
            ],
            "outputs": [
            ],
            "execution_count": 1
        },
        {
            "id": "17",
            "cell_type": "markdown",
            "metadata": {
            },
            "source": [
            ]
        },
        {
            "id": "18",
            "cell_type": "code",
            "metadata": {
            },
            "source": [
                "with_theme(theme_latexfonts()) do\n",
                "    plot_orbit(star, \"images/rk4.svg\")\n",
                "end;"
            ],
